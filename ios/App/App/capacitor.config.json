{
	"appId": "closeshop.dev",
	"appName": "closeshop-dev",
	"webDir": "dist",
	"bundledWebRuntime": false,
	"server": {
		"androidScheme": "https",
		"cleartext": true
	},
	"plugins": {
		"CapacitorHttp": {
			"enabled": true
		}
	},
	"packageClassList": [
		"AppPlugin",
		"AppLauncherPlugin",
		"CAPBrowserPlugin",
		"CAPCameraPlugin",
		"GeolocationPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"LocalNotificationsPlugin",
		"CAPNetworkPlugin",
		"PushNotificationsPlugin",
		"StatusBarPlugin",
		"GoogleSignInPlugin"
	]
}
